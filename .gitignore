# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
Icon?

# --- Xcode / SwiftPM ---
# Generated by xcodegen, never hand-edit:
*.xcodeproj/
*.xcworkspace/
# SwiftPM build artifacts:
.build/
.swiftpm/
Package.resolved
# Xcode-managed:
DerivedData/
xcuserdata/
*.xcuserstate
*.xcscmblueprint
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# --- Bridge build outputs ---
macos-app/build/
macos-app/Generated/

# --- App Store screenshots (contain real lock names / HA IPs) ---
# The composer script (make_appstore_screenshots.py) is tracked; the raw grabs
# and generated images are not — they leak private home/network details.
macos-app/Resources/screenshots/

# --- Local team config (each contributor sets their own) ---
macos-app/DevelopmentTeam.xcconfig

# --- Runtime config / state ---
# Bearer tokens live in ~/Library/Application Support/HALockBridge/.
# Belt-and-suspenders: refuse to commit any local config file by convention.
*.local.json
config.local.json

# --- Possible cert/key material that should never land in the repo ---
*.pem
*.key
*.p12
*.mobileprovision
*.provisionprofile

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# --- Editors / AI assistants ---
.vscode/
.idea/
*.swp
*.swo
*~
*.bak
.zed/
.claude/
.aider*
.cursor/
.continue/

# --- Misc ---
*.log
.envrc
node_modules/
.cache/
